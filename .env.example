# Lucille Environment Configuration
# Copy this file to .env and configure for your environment

# FRAMEWORK SETTINGS
LUCILLE_PARALLEL_THREADS=3
LUCILLE_TIMEOUT=30
LUCILLE_VERBOSE=false
LUCILLE_DEBUG=false

# SCANNING SETTINGS
LUCILLE_PORT_RANGE=1-65535
LUCILLE_COMMON_PORTS=22,25,53,80,110,143,443,445,3306,3389,5432,8080,8443
LUCILLE_WORDLIST=data/wordlists/common.txt
LUCILLE_USER_AGENT=Lucille/1.0
LUCILLE_THREAD_COUNT=4
LUCILLE_REQUEST_TIMEOUT=10

# API KEYS (OPTIONAL)
# Shodan
SHODAN_API_KEY=

# VirusTotal
VIRUSTOTAL_API_KEY=

# Censys
CENSYS_API_ID=
CENSYS_API_SECRET=

# HaveIBeenPwned
HIBP_ENABLED=true

# OUTPUT SETTINGS
LUCILLE_OUTPUT_DIR=results
LUCILLE_OUTPUT_FORMAT=json
LUCILLE_CREATE_TIMESTAMP_DIR=true

# PERFORMANCE
LUCILLE_CACHE_RESULTS=true
LUCILLE_CACHE_TTL=86400

# SSL/TLS
LUCILLE_VERIFY_SSL=false
LUCILLE_SSL_TIMEOUT=10

# LOGGING
LUCILLE_LOG_LEVEL=INFO
LUCILLE_LOG_FILE=lucille.log
LUCILLE_LOG_CONSOLE=true
